<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">  <!-- 矩形形状 -->

    <!-- 圆角设置 -->
    <corners
        android:radius="8dp"/>


    <!-- 边框设置 -->
    <stroke
        android:width="2dp"
        android:color="#374151" />

    <!-- 填充颜色 -->
    <solid android:color="#191D23"/>

    <!-- 内边距（可选） -->
    <padding
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp"/>

</shape>