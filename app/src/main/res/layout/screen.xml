<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/gray">
    <ImageView
        android:id="@+id/traceback"
        android:src="@drawable/traceback"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="28dp"
        android:layout_marginStart="44dp"
        android:contentDescription="返回"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="屏幕补光"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_settings"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="44dp"
        android:src="@drawable/ic_settings"
        android:contentDescription="设置"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <TextView
        android:id="@+id/text1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="效果预览"
        android:textColor="@color/white"
        android:layout_marginTop="25dp"
        android:textSize="16sp"/>
    <LinearLayout
        android:id="@+id/card1"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginStart="44dp"
        android:layout_marginEnd="44dp"
        android:layout_marginTop="15dp"
        android:background="@drawable/bg_rounded_corner"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@+id/text1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_bulb" />
        <TextView
            android:id="@+id/tv_light_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="白光-亮度"
            android:textSize="20sp"
            android:textColor="@color/grey" />

    </LinearLayout>
    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/card1"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="44dp"
        android:text="效果预览"
        android:textColor="@color/white"
        android:layout_marginTop="25dp"
        android:textSize="16sp"/>
    <LinearLayout
        android:id="@+id/card_left"
        android:layout_width="70dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_rounded_selector"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toStartOf="@+id/card_middle"
        app:layout_constraintTop_toTopOf="@+id/card_middle">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="低\n40%"
        android:textColor="@color/white"
        android:gravity="center"
        android:textSize="15sp"/>
</LinearLayout>


    <LinearLayout
        android:id="@+id/card_middle"
        android:layout_width="70dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_rounded_selector"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@+id/textView"
        android:layout_marginTop="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="中\n70%"
            android:textColor="@color/white"
            android:gravity="center"
            android:textSize="15sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/card_right"
        android:layout_width="70dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_rounded_selector"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toEndOf="@+id/card_middle"
        app:layout_constraintTop_toTopOf="@+id/card_middle" >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="高\n100%"
            android:textColor="@color/white"
            android:gravity="center"
            android:textSize="15sp"/>
    </LinearLayout>
    <TextView
        android:id="@+id/textView1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/card_left"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="44dp"
        android:text="色彩选择"
        android:textColor="@color/white"
        android:layout_marginTop="25dp"
        android:textSize="16sp"/>
    <LinearLayout
        android:id="@+id/card_left1"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_rounded_selector"
        android:orientation="vertical"
        android:layout_marginEnd="20dp"
        android:gravity="center"
        app:layout_constraintEnd_toStartOf="@+id/card_middle1"
        app:layout_constraintTop_toTopOf="@+id/card_middle1">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/bg_white" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="纯白光"
            android:textSize="13sp"
            android:textColor="@color/pure_white" />
    </LinearLayout>



    <LinearLayout
        android:id="@+id/card_middle1"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_rounded_selector"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView1"
        android:layout_marginTop="20dp">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/bg_warm_white" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="暖白光"
            android:textSize="13sp"
            android:textColor="@color/pure_white" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/card_right1"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_rounded_selector"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toEndOf="@+id/card_middle1"
        app:layout_constraintTop_toTopOf="@+id/card_middle1" >
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/bg_cold_white" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="冷白光"
            android:textSize="13sp"
            android:textColor="@color/pure_white" />
    </LinearLayout>
    <Button
        android:id="@+id/card2"
        android:layout_width="150dp"
        android:layout_height="50dp"
        android:layout_marginStart="44dp"
        android:layout_marginEnd="44dp"
        android:layout_marginTop="25dp"
        android:background="@drawable/bg_rounded_corner"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/card_middle1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="💡开启补光"
        android:textSize="16sp">
    </Button>
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="44dp"
        android:layout_marginEnd="44dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_rounded_corner_differ"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/card2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:layout_weight="1"
                    android:text="自动关闭"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:id="@+id/tv_screen_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5分钟"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:textSize="12sp"
                    android:textColor="#8E8E93 "
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="10dp"
                    app:layout_constraintBaseline_toTopOf="@id/btn_switch"
                    app:layout_constraintEnd_toEndOf="@id/btn_switch" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:layout_weight="5"
                    android:text="护眼模式" />
                <com.name.FlashLight.SlidingButton
                    android:id="@+id/btn_switch"
                    android:layout_width="0dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:gravity="end" />
            </LinearLayout>

        </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>