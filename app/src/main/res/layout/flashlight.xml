<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/black">
    <ImageView
        android:id="@+id/traceback"
        android:src="@drawable/traceback"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="28dp"
        android:layout_marginStart="44dp"
        android:contentDescription="返回"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="手电筒"

        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_settings"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="44dp"
        android:src="@drawable/ic_settings"
        android:contentDescription="设置"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/card_container"
        android:layout_width="0dp"
        android:layout_height="75dp"
        android:layout_marginStart="44dp"
        android:layout_marginEnd="44dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_rounded_corner"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        >

        <!-- 左边：电池图标 -->
        <ImageView
            android:id="@+id/iv_battery_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_battery_75"
            android:layout_marginEnd="12dp"/>

        <!-- 中间：左侧信息组 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_battery_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="电量：85%"
                android:textColor="@color/white"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tv_battery_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="充电中 ⚡"
                android:textColor="#9BA28F"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- 右边：时间显示组 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="使用时间"
                android:textColor="#9BA28F"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/tv_flashlight_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:15"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_flashlight"
        android:layout_width="160dp"
        android:layout_height="160dp"
        app:layout_constraintTop_toBottomOf="@+id/card_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:background="@drawable/btn_flashlight_off"
        android:layout_marginTop="30dp"
        android:text="关闭" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="30dp"
        android:text="亮度档位"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_flashlight" />


    <LinearLayout
        android:id="@+id/card_left"
        android:layout_width="70dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_rounded_selector"
        android:orientation="vertical"
        android:layout_marginEnd="20dp"
        android:gravity="center"
        app:layout_constraintEnd_toStartOf="@+id/card_middle"
        app:layout_constraintTop_toTopOf="@+id/card_middle">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="低\n40%"
            android:textColor="@color/white"
            android:gravity="center"
            android:textSize="15dp"/>
    </LinearLayout>




    <LinearLayout
        android:id="@+id/card_middle"
        android:layout_width="70dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_rounded_selector"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@+id/textView"
        android:layout_marginTop="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="中\n70%"
            android:textColor="@color/white"
            android:gravity="center"
            android:textSize="15dp"/>
    </LinearLayout>



    <LinearLayout
        android:id="@+id/card_right"
        android:layout_width="70dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_rounded_selector"
        android:orientation="vertical"
        android:layout_marginStart="20dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@+id/card_middle"
        app:layout_constraintTop_toTopOf="@+id/card_middle" >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="高\n100%"
            android:textColor="@color/white"
            android:gravity="center"
            android:textSize="15dp"/>
    </LinearLayout>

    <!-- 设置打包居中 -->

    <LinearLayout
        android:id="@+id/card"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginStart="44dp"
        android:layout_marginEnd="44dp"
        android:layout_marginTop="20dp"
        android:padding="16dp"
        android:background="@drawable/bg_rounded_corner"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/card_middle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自动关闭"
                android:layout_weight="1"
                android:textColor="@color/white"/>
            <TextView
                android:id="@+id/tv_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5分钟"
                android:textColor="@color/grey"
                android:layout_weight="1"
                android:gravity="end"/>
        </LinearLayout>
        <FrameLayout
            android:id="@+id/frameLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ProgressBar
                android:id="@+id/progress_flashlight"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="12dp"
                style="?android:attr/progressBarStyleHorizontal"
                android:progressDrawable="@drawable/progress_bar" />
            <TextView
                android:id="@+id/last_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="0分钟"
                android:textColor="@color/grey"
                android:layout_weight="1"
                android:gravity="end"/>
        </FrameLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="44dp"
        android:layout_marginEnd="44dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_rounded_corner"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    </LinearLayout>




</androidx.constraintlayout.widget.ConstraintLayout>