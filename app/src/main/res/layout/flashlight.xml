<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/black">

    <ImageView
        android:id="@+id/traceback"
        android:src="@drawable/traceback"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="28dp"
        android:layout_marginStart="44dp"
        android:contentDescription="返回"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/title_flashlight"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_settings"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="44dp"
        android:src="@drawable/ic_settings"
        android:contentDescription="设置"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/card_container"
        android:layout_width="0dp"
        android:layout_height="75dp"
        android:layout_marginStart="44dp"
        android:layout_marginEnd="44dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_rounded_corner"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        >

        <ImageView
            android:id="@+id/iv_battery_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_battery_75"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_battery_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="电量：85%"
                android:textColor="@color/white"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tv_battery_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="充电中 ⚡"
                android:textColor="#9BA28F"
                android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/usage_time"
                android:textColor="#9BA28F"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/tv_flashlight_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 光晕层：放在按钮下方，通过约束对齐按钮中心 -->
    <View
        android:id="@+id/view_halo"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:alpha="0"
        android:visibility="gone"
        android:background="@drawable/bg_flashlight_halo"
        app:layout_constraintTop_toTopOf="@id/btn_flashlight"
        app:layout_constraintBottom_toBottomOf="@id/btn_flashlight"
        app:layout_constraintStart_toStartOf="@id/btn_flashlight"
        app:layout_constraintEnd_toEndOf="@id/btn_flashlight" />

    <!-- 按钮：恢复原始约束，确保位置不变 -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_flashlight"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/btn_flashlight_off"
        android:text="@string/btn_off"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@+id/card_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="30dp"
        android:text="@string/brightness_level"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_flashlight" />

    <LinearLayout
        android:id="@+id/card_left"
        android:layout_width="70dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_rounded_selector"
        android:orientation="vertical"
        android:layout_marginEnd="20dp"
        android:gravity="center"
        app:layout_constraintEnd_toStartOf="@+id/card_middle"
        app:layout_constraintTop_toTopOf="@+id/card_middle">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/brightness_card_low"
            android:textColor="@color/white"
            android:gravity="center"
            android:textSize="15dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/card_middle"
        android:layout_width="70dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_rounded_selector"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@+id/textView"
        android:layout_marginTop="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/brightness_card_medium"
            android:textColor="@color/white"
            android:gravity="center"
            android:textSize="15dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/card_right"
        android:layout_width="70dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_rounded_selector"
        android:orientation="vertical"
        android:layout_marginStart="20dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@+id/card_middle"
        app:layout_constraintTop_toTopOf="@+id/card_middle" >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/brightness_card_high"
            android:textColor="@color/white"
            android:gravity="center"
            android:textSize="15dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/card"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginStart="44dp"
        android:layout_marginEnd="44dp"
        android:layout_marginTop="20dp"
        android:padding="16dp"
        android:background="@drawable/bg_rounded_corner"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/card_middle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_clock"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/setting_auto_off"
                android:layout_marginLeft="4dp"
                android:layout_weight="1"
                android:textColor="@color/white"/>
            <TextView
                android:id="@+id/tv_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5分钟"
                android:textColor="@color/grey"
                android:gravity="end"/>
        </LinearLayout>
        <FrameLayout
            android:id="@+id/frameLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ProgressBar
                android:id="@+id/progress_flashlight"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="12dp"
                style="?android:attr/progressBarStyleHorizontal"
                android:progressDrawable="@drawable/progress_bar" />
            <TextView
                android:id="@+id/last_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="00:00"
                android:textColor="@color/grey"
                android:layout_weight="1"
                android:gravity="end"/>
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/temperature_container"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_marginStart="44dp"
        android:layout_marginEnd="44dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_rounded_corner"
        android:gravity="center_vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView
            android:id="@+id/iv_temperature"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/temperature" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:layout_marginStart="4dp">
            <TextView
                android:id="@+id/tv_temperature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/normal_temperature"
                android:textColor="@color/white"
                android:textSize="14sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/allow_for_ventilation"
                android:textColor="@color/grey"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>