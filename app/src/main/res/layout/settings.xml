<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/gray">
    <ImageView
        android:id="@+id/traceback"
        android:src="@drawable/traceback"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="28dp"
        android:layout_marginStart="44dp"
        android:contentDescription="返回"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/title_settings"

        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_settings"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="44dp"
        android:src="@drawable/ic_settings"
        android:contentDescription="设置"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="?attr/actionBarSize"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"
        app:layout_constraintBottom_toBottomOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/automatic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <ImageView
                android:id="@+id/icon1"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_settings"
                android:layout_marginStart="40dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/basic_settings"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:layout_marginStart="6dp"
                app:layout_constraintStart_toEndOf="@+id/icon1"
                app:layout_constraintTop_toTopOf="@+id/icon1"/>
            <LinearLayout
                android:id="@+id/card_container1"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_rounded_top"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/icon1">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_clock"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_auto_off"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/set_auto_off_time"
                        android:textSize="12sp"
                        android:textColor="@color/grey" />
                </LinearLayout>
                <ImageView
                    android:id="@+id/arrow_close"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/arrow_right"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/card_container2"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="-2dp"
                android:background="@drawable/bg_rounded_middle"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_container1">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_launcher"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_startup_mode"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/set_startup_behaviour"
                        android:textColor="@color/grey"
                        android:textSize="12sp"/>
                </LinearLayout>

                <Spinner
                    android:id="@+id/spinner_startup_mode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_rounded_corner"
                    android:dropDownSelector="@drawable/spinner_selector"
                    android:popupBackground="@drawable/bg_rounded_corner" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/card_container3"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="-2dp"
                android:background="@drawable/bg_rounded_bottom"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_container2">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_brighrtness"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_brightness"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/set_brightness"
                        android:textColor="@color/grey"
                        android:textSize="12sp"/>
                </LinearLayout>
                <Spinner
                    android:id="@+id/spinner_brightness"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_rounded_corner"
                    android:dropDownSelector="@drawable/spinner_selector"
                    android:popupBackground="@drawable/bg_rounded_corner" />

            </LinearLayout>
            <ImageView
                android:id="@+id/icon2"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_palette"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@+id/card_container3"
                app:layout_constraintStart_toStartOf="@id/icon1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/page_settings"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:layout_marginStart="6dp"
                app:layout_constraintTop_toTopOf="@id/icon2"
                app:layout_constraintStart_toEndOf="@+id/icon2"/>
            <LinearLayout
                android:id="@+id/card_container4"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_rounded_top"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/icon2">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_settings"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="主题选择"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="深色、浅色或跟随系统"
                        android:textColor="@color/grey"
                        android:textSize="12sp"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/theme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="深色主题"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_rounded_corner"
                    android:layout_marginStart="12dp"/>

            </LinearLayout>
            <LinearLayout
                android:id="@+id/card_container5"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="-2dp"
                android:background="@drawable/bg_rounded_middle"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_container4">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_settings"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/language_settings"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/choose_display_language"
                        android:textColor="@color/grey"
                        android:textSize="12sp"/>
                </LinearLayout>
                <Spinner
                    android:id="@+id/spinner_language"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_rounded_corner"
                    android:dropDownSelector="@drawable/spinner_selector"
                    android:popupBackground="@drawable/bg_rounded_corner" />

            </LinearLayout>
            <LinearLayout
                android:id="@+id/card_container6"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="-2dp"
                android:background="@drawable/bg_rounded_bottom"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_container5">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_settings"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="字体大小"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="调整界面文字大小"
                        android:textColor="@color/grey"
                        android:textSize="12sp"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="标准"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_rounded_corner"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
            <ImageView
                android:id="@+id/icon3"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_settings_differ"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@+id/card_container6"
                app:layout_constraintStart_toStartOf="@id/icon1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="功能设置"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:layout_marginStart="6dp"
                app:layout_constraintTop_toTopOf="@id/icon3"
                app:layout_constraintStart_toEndOf="@+id/icon3"/>
            <LinearLayout
                android:id="@+id/card_container7"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_rounded_top"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/icon3">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_phone" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_vibration"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/vibration_feedback"
                        android:textColor="@color/grey"
                        android:textSize="12sp"/>
                </LinearLayout>
                <com.name.FlashLight.SlidingButton
                    android:id="@+id/btn_vibration"
                    android:layout_width="40dp"
                    android:layout_height="20dp"
                    android:gravity="end" />

            </LinearLayout>
            <LinearLayout
                android:id="@+id/card_container8"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="-2dp"
                android:background="@drawable/bg_rounded_middle"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_container7">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_volume"
                    android:layout_marginStart="-6dp"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_sound"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sound_feedback"
                        android:textColor="@color/grey"
                        android:textSize="12sp"/>
                </LinearLayout>
                <com.name.FlashLight.SlidingButton
                    android:id="@+id/sliding_sound"
                    android:layout_width="40dp"
                    android:layout_height="20dp"
                    android:gravity="end" />

            </LinearLayout>
            <LinearLayout
                android:id="@+id/card_container9"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="-2dp"
                android:background="@drawable/bg_rounded_bottom"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_container8">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_eye"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/eye_protection_mode"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_brightness_adjustment"
                        android:textColor="@color/grey"
                        android:textSize="12sp"/>
                </LinearLayout>
                <com.name.FlashLight.SlidingButton
                    android:id="@+id/sliding_auto_brightness"
                    android:layout_width="40dp"
                    android:layout_height="20dp"
                    android:gravity="end" />
            </LinearLayout>
            <ImageView
                android:id="@+id/icon4"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_data"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@+id/card_container9"
                app:layout_constraintStart_toStartOf="@id/icon1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/data_management"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:layout_marginStart="6dp"
                app:layout_constraintTop_toTopOf="@id/icon4"
                app:layout_constraintStart_toEndOf="@+id/icon4"/>
            <LinearLayout
                android:id="@+id/card_container10"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_rounded_top"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/icon4">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_stats"
                    android:layout_marginStart="-3dp"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/usage_stats"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/check_usage_situation"
                        android:textColor="@color/grey"
                        android:textSize="12sp"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/arrow_stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/arrow_right"
                    android:layout_marginStart="12dp"/>

            </LinearLayout>
            <LinearLayout
                android:id="@+id/card_container11"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="-2dp"
                android:background="@drawable/bg_rounded_middle"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_container10">

            </LinearLayout>
            <LinearLayout
                android:id="@+id/card_container12"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="-2dp"
                android:background="@drawable/bg_rounded_bottom"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_container11">
            </LinearLayout>
            <ImageView
                android:id="@+id/icon5"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_settings"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@+id/card_container12"
                app:layout_constraintStart_toStartOf="@id/icon1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about_application"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:layout_marginStart="6dp"
                app:layout_constraintTop_toTopOf="@id/icon5"
                app:layout_constraintStart_toEndOf="@+id/icon5"/>
            <LinearLayout
                android:id="@+id/card_container13"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_rounded_top"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/icon5">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_settings"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/version_info"
                    android:gravity="center"
                    android:layout_weight="1"
                    android:textSize="16sp"
                    android:textColor="@color/white"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v1.0.0"
                    android:textColor="@color/grey"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_container14"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="-2dp"
